# Art & Anchal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Supabase (Frontend + Backend) ───────────────────────────────────────────
# Your Supabase project URL (found in: Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (safe to expose to browser)
# Found in: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Supabase (Server-side only, NOT exposed to browser) ─────────────────────
# Same URL as above but without VITE_ prefix — for use in Node.js server
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key — NEVER expose this to the browser!
# Found in: Supabase Dashboard → Project Settings → API → service_role
# Required for: webhook handler (needs to bypass Row Level Security)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Razorpay (Server-side only) ─────────────────────────────────────────────
# Razorpay Key ID (safe to expose to frontend for Razorpay checkout modal)
# Found in: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Razorpay Key Secret — NEVER expose to browser!
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Razorpay Webhook Secret — Used to verify webhook signature
# Found in: Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Server ───────────────────────────────────────────────────────────────────
# Port for the Express API server (default: 3001)
PORT=3001

# Node environment: 'development' or 'production'
NODE_ENV=development
